#1.TO CHECK WHETHER A NUMBER CAN BE EXPRESSED AS SUM OF TWO PRIME NUMBERS USING FUNCTION.
def is_prime(n):
    if n < 2:
        return False
    for i in range(2, n):
        if n % i == 0:
            return False
    return True
def check_sum(num):
    for i in range(2, num):
        if is_prime(i) and is_prime(num - i):
            print(num, "=", i, "+", num - i)
            return
    print("Not possible")
n = int(input("Enter a number: "))
check_sum(n)
